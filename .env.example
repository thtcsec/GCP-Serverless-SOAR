# GCP Serverless SOAR Environment Variables
# Note: In production, these are injected by GCP Cloud Functions environment configuration.
# This file is provided for local development and documentation purposes.

# Core Configuration
PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCP_ZONE=us-central1-a
LOG_LEVEL=INFO

# Alerting and Thresholds
ALERT_TOPIC=projects/your-gcp-project-id/topics/security-alerts
DLQ_TOPIC=projects/your-gcp-project-id/topics/soar-dlq
EXFILTRATION_THRESHOLD=10737418240
SEVERITY_THRESHOLD=7.0
APPROVAL_WAIT_TIME=3600

# GCP Specific Security Settings
ISOLATION_TAG=isolated-vm
ISOLATION_FIREWALL_NAME=soar-isolation-deny-all
FORENSIC_BUCKET=your-gcp-project-id-forensic-data
FORENSIC_JUMP_HOST_IP=10.0.0.5

# Step Functions / Workflows
WORKFLOW_NAME=projects/your-gcp-project-id/locations/us-central1/workflows/soar-main
GUARDDUTY_WORKFLOW=soar-incident-response
IAM_WORKFLOW=soar-sa-response
STORAGE_WORKFLOW=soar-storage-response

# Third-Party Integrations
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
SIEM_TYPE=chronicle
SIEM_ENDPOINT=https://your-chronicle-endpoint
SIEM_API_KEY=your-api-key
JIRA_URL=https://your-domain.atlassian.net
JIRA_USERNAME=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=SEC
